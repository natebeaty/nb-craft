{% set query = craft.request.getParam('q') %}
{% set results = craft.entries({
	search: {
	    query: query,
	    subLeft: true,
	    subRight: true
	}
}) %}
{
	"entries" : [
		{% for entry in results %}
			{ "title": "{{ entry.title }}", "url": "{{ entry.url }}" }{% if not loop.last %},{% endif %}
		{% endfor %}
	]
}